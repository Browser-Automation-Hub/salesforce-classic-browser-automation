  },
  "keywords": [
    "salesforce",
    "salesforce-classic",
    "crm-automation",
    "browser-automation",
    "puppeteer",
    "playwright",
    "anchorbrowser",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^21.0.0",
    "dotenv": "^16.0.0",
    "otpauth": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Browser-Automation-Hub/salesforce-classic-browser-automation.git"
  },
