  "description": "Browser automation for Salesforce Classic — create/update records, run reports, manage leads, and automate CRM workflows for orgs that cannot migrate to Lightning.",
  "main": "src/actions.js",
  "scripts": {
    "start": "node examples/basic-login.js",
    "start:cloud": "node examples/anchor-cloud.js",
